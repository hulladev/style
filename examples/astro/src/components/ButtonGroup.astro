---
import { cn, vn } from '@/lib/style.ts'

const $size = vn({
  sm: 'size-sm',
  md: 'size-md',
  lg: 'size-lg'
})

const $color = vn({
  primary: 'color-primary',
  secondary: 'color-secondary'
})

interface Props {
  size?: typeof $size.infer
  color?: typeof $color.infer
}

const { size = 'md', color = 'primary' } = Astro.props
---

<button class={cn($size(size), $color(color))}><slot /></button>

<style>
  button {
    border: 2px solid;
    cursor: pointer;
  }
  button:hover {
    opacity: 0.8;
  }
  .size-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.875rem;
  }
  .size-md {
    padding: 0.5rem 1rem;
    font-size: 1rem;
  }
  .size-lg {
    padding: 0.75rem 1.5rem;
    font-size: 1.125rem;
  }
  .color-primary {
    color: greenyellow;
    border-color: greenyellow;
  }
  .color-secondary {
    color: aquamarine;
    border-color: aquamarine;
  }
</style>
