{
  "name": "@hulla/style",
  "version": "0.3.0",
  "description": "Styling made easy 🎨",
  "author": {
    "name": "Samuel Hulla",
    "email": "hulla@hulla.dev",
    "url": "https://hulla.dev"
  },
  "maintainers": [
    "Samuel Hulla <hulla@hulla.dev>"
  ],
  "homepage": "https://hulla.dev/projects/style",
  "repository": {
    "type": "git",
    "url": "https://github.com/hulladev/style.git",
    "directory": "packages/style"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/es/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint . --fix",
    "build": "bunchee -m",
    "test": "vitest run tests/index.test.ts && pnpm run test:types",
    "test:types": "pnpm --dir ../.. exec tsc -p packages/style/tsconfig.types.json --noEmit"
  },
  "devDependencies": {
    "astro": "^4.10.3",
    "bunchee": "^5.2.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "vitest": "^1.6.0"
  }
}
